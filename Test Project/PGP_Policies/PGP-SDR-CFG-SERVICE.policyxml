<?xml version="1.0" encoding="UTF-8"?>
<policies>
    <policy longDescription="Used by encryption flow to encrypt messages for the receiver" policyName="PGP-SDR-CFG-SERVICE" policyTemplate="UserDefined" policyType="UserDefined" shortDescription="Sender Policy" version="1.0">
        <DefaultDecryptionKeyPassphrase>passw0rd</DefaultDecryptionKeyPassphrase>
        <DefaultSignKeyPassphrase>passw0rd</DefaultSignKeyPassphrase>
        <DefaultSignKeyUserId>Sender &lt;sender@testpgp.com&gt;</DefaultSignKeyUserId>
        <PrivateKeyRepository>C:/temp/pgp/keys/sender-private-repository.pgp</PrivateKeyRepository>
        <PublicKeyRepository>C:/temp/pgp/keys/sender-public-repository.pgp</PublicKeyRepository>
    </policy>
</policies>
